{
  "name": "agent-tabs",
  "displayName": "Agent Tabs",
  "description": "Browse your Claude Code chat history as browser-style tabs — with bookmarks, search, and project grouping. 100% local, no telemetry.",
  "version": "0.2.0",
  "publisher": "squirrelx11",
  "license": "MIT",
  "author": {
    "name": "Alex"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#181818",
    "theme": "dark"
  },
  "homepage": "https://github.com/SquirrelX11/agent-tabs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SquirrelX11/agent-tabs.git"
  },
  "bugs": {
    "url": "https://github.com/SquirrelX11/agent-tabs/issues"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude code",
    "ai",
    "chat history",
    "tabs"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentTabs.quickOpen",
        "title": "Go to Chat…",
        "category": "Agent Tabs",
        "icon": {
          "light": "resources/agent-tabs-light.svg",
          "dark": "resources/agent-tabs-dark.svg"
        }
      },
      {
        "command": "agentTabs.open",
        "title": "Open Chat Panel",
        "category": "Agent Tabs",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agentTabs.refresh",
        "title": "Refresh Session List",
        "category": "Agent Tabs",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agentTabs.quickOpen"
        },
        {
          "command": "agentTabs.open"
        },
        {
          "command": "agentTabs.refresh"
        }
      ],
      "editor/title": [
        {
          "command": "agentTabs.quickOpen",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "Agent Tabs",
      "properties": {
        "agentTabs.projectsDir": {
          "type": "string",
          "default": "",
          "description": "Folder to read Claude Code sessions from. Empty = ~/.claude/projects"
        },
        "agentTabs.maxMessagesPerChat": {
          "type": "number",
          "default": 800,
          "description": "Maximum number of messages rendered in a single chat (guards against enormous sessions)."
        },
        "agentTabs.openChatsIn": {
          "type": "string",
          "enum": [
            "claude-code",
            "built-in-viewer"
          ],
          "enumDescriptions": [
            "Open the live Claude Code chat, so you can carry on where you left off.",
            "Open the read-only viewer built into Agent Tabs."
          ],
          "default": "claude-code",
          "description": "What happens when you pick a chat. Falls back to the built-in viewer if the Claude Code extension can't be reached."
        }
      }
    },
    "keybindings": [
      {
        "command": "agentTabs.quickOpen",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "agentTabs.open",
        "key": "ctrl+alt+shift+a",
        "mac": "cmd+alt+shift+a"
      }
    ]
  },
  "scripts": {
    "package": "npx --yes @vscode/vsce package",
    "publish:ovsx": "npx --yes ovsx publish -p $OVSX_TOKEN"
  }
}
